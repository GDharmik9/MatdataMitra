rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --------------------------------------------------------------------
    // MATDATAMITRA - Strict Hackathon Security Rules
    // By default, the frontend relies on Cloud Run backend API.
    // We only allow highly restricted read access if clients connect directly.
    // --------------------------------------------------------------------
    
    // Fallback: Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Read-only access to public election guidelines
    match /guidelines/{docId} {
      allow read: if true;
      allow write: if false; // Only Admin SDK can write
    }

    // Users can only read their own verification data if authenticated
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Only Admin SDK manages user records
    }
  }
}
