# ============================================================
# MatdataMitra — Environment Variables
# Copy this file to .env and fill in your actual keys
# ============================================================

# --- Google Cloud ---
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
# Auth: Run 'gcloud auth application-default login' (no key file needed)
GCS_BUCKET_NAME=matdata-mitra-documents

# --- Google Gemini AI ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# --- Firebase (Frontend) ---
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# --- Language Support ---
# Translation: Google Cloud Translation API (auto-enabled via service account)
# STT: Google Cloud Speech-to-Text (auto-enabled via service account)
# TTS: Google Cloud Text-to-Speech (auto-enabled via service account)
# All three use GOOGLE_APPLICATION_CREDENTIALS above — no separate API keys needed

# --- Voter Verification ---
# Uses mock data for hackathon demo (no external API required)

# --- Google Civic Information API ---
CIVIC_API_KEY=your-google-civic-api-key

# --- WhatsApp Business API (Meta Developer Sandbox) ---
WHATSAPP_VERIFY_TOKEN=your-custom-verify-token
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# --- Server Configuration ---
PORT=8080
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
WHATSAPP_RATE_LIMIT_MAX=20
